{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": false
  },
  "include": ["src", "claude/scripts/**/*.mjs", "claude/schemas/**/*.json"]
}
